{
  "name": "ai-pm-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./dist/output.css",
    "watch": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
"dev": "npm run build && serve . -p 3000",
"start": "serve . -p 3000",
"build:watch": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch"
  },
  "devDependencies": {
    "serve": "^14.2.6",
    "tailwindcss": "^3.4.0"
  }
}
